{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenClawTrajectoryOpenClawInstallState",
  "type": "object",
  "required": ["schema_version", "phase", "started_at", "updated_at", "home", "base_dir", "report_path", "log_path", "steps"],
  "properties": {
    "schema_version": { "const": "openclaw.trajectory-openclaw-install-state/v1" },
    "phase": { "type": "string" },
    "started_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "home": { "type": "string" },
    "openclaw_home": { "type": "string" },
    "openclaw_config_path": { "type": "string" },
    "base_dir": { "type": "string" },
    "report_path": { "type": "string" },
    "log_path": { "type": "string" },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "started_at"],
        "properties": {
          "name": { "type": "string" },
          "status": { "enum": ["running", "ok", "warning", "error"] },
          "command": { "type": "string" },
          "started_at": { "type": "string" },
          "ended_at": { "type": "string" },
          "exit_code": { "type": "integer" },
          "stdout_tail": { "type": "string" },
          "stderr_tail": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
