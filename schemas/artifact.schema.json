{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenClawArtifact",
  "type": "object",
  "required": ["schema_version", "artifact_id", "uri", "kind", "mime_type", "sha256", "size_bytes", "created_at", "summary", "redacted", "redacted_keys", "metadata"],
  "properties": {
    "schema_version": { "const": "openclaw.artifact/v1" },
    "artifact_id": { "type": "string", "minLength": 1 },
    "uri": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "minLength": 1 },
    "mime_type": { "type": "string", "minLength": 1 },
    "sha256": { "type": "string", "minLength": 64 },
    "size_bytes": { "type": "number" },
    "created_at": { "type": "string" },
    "summary": { "type": ["string", "null"] },
    "redacted": { "type": "boolean" },
    "redacted_keys": { "type": "array", "items": { "type": "string", "pattern": "^/" } },
    "metadata": {
      "type": "object",
      "required": ["summary_source"],
      "properties": {
        "summary_source": {
          "enum": ["none", "deterministic", "deterministic_budget_exhausted", "llm", "llm_cache"]
        },
        "input_tokens": { "type": "number", "minimum": 0 },
        "output_tokens": { "type": "number", "minimum": 0 },
        "total_tokens": { "type": "number", "minimum": 0 },
        "cost_usd": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
