{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenClawToolSpec",
  "type": "object",
  "required": ["schema_version", "namespace", "name", "version", "input_schema", "output_schema", "side_effect", "determinism"],
  "properties": {
    "schema_version": { "const": "openclaw.tool/v1" },
    "namespace": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "input_schema": { "type": "object", "additionalProperties": true },
    "output_schema": { "type": "object", "additionalProperties": true },
    "side_effect": { "enum": ["read_only", "write", "network", "external_mutation", "unknown"] },
    "determinism": { "enum": ["deterministic", "non_deterministic", "unknown"] },
    "timeout_ms": { "type": "number" },
    "auth_scope": { "type": "array", "items": { "type": "string" } },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": false
}
