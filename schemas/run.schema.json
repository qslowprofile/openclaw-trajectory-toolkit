{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenClawRun",
  "type": "object",
  "required": ["schema_version", "run_id", "trace_id", "root_span_id", "input", "started_at", "last_event_at", "status", "metadata"],
  "properties": {
    "schema_version": { "const": "openclaw.run/v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "minLength": 16 },
    "root_span_id": { "type": "string", "minLength": 1 },
    "session_id": { "type": ["string", "null"] },
    "session_key": { "type": ["string", "null"] },
    "root_session_id": { "type": ["string", "null"] },
    "parent_session_id": { "type": ["string", "null"] },
    "agent_id": { "type": ["string", "null"] },
    "agent_name": { "type": ["string", "null"] },
    "input": {},
    "output": {},
    "started_at": { "type": "string" },
    "ended_at": { "type": ["string", "null"] },
    "last_event_at": { "type": "string" },
    "status": { "enum": ["running", "ending", "ok", "error", "cancelled", "timeout"] },
    "pending_final_status": { "enum": ["ok", "error", "cancelled", "timeout"] },
    "pending_ended_at": { "type": "string" },
    "pending_output": {},
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": true
}
