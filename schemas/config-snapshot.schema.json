{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenClawConfigSnapshot",
  "type": "object",
  "required": ["schema_version", "captured_at", "trajectory"],
  "properties": {
    "schema_version": { "const": "openclaw.config-snapshot/v1" },
    "captured_at": { "type": "string" },
    "trajectory": {
      "type": "object",
      "required": ["mode", "local_dir"],
      "properties": {
        "mode": { "type": "string" },
        "local_dir": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
